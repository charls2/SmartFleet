# Backend API (default matches npm run dev in backend on port 8080)
VITE_API_URL=http://localhost:8080

# Local dev without Firebase sign-in: use x-company-id (e.g. cmp_1 after npm run seed in backend).
# Omit or any value except "false" enables header mode. Set to false to require Firebase sign-in only.
VITE_ALLOW_HEADER_TENANT=true

# Firebase Web App config (Firebase Console → Project settings → Your apps → Web app).
# Required for sign-in / company registration. Omit only if you rely on tenant header mode above.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
