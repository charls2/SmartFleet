# Server
PORT=8080

# Firestore: use Application Default Credentials (GOOGLE_APPLICATION_CREDENTIALS)
# or set path to service account JSON:
GOOGLE_APPLICATION_CREDENTIALS=./smartfleet-e5bdc-firebase-adminsdk-fbsvc-d0293a17e2.json

# Local Firestore emulator (optional)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# Project ID (same as Firebase project id). Optional if your service account JSON is set — it is read automatically.
GCLOUD_PROJECT=your-firebase-project-id

# Auth: header mode for local dev (sends x-company-id). Set to firebase for ID token only.
AUTH_MODE=header

# Seed demo data (after Firestore API is enabled in Firebase console):
# npm run seed
